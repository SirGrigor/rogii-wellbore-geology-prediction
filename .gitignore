# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Data — large / downloaded; never commit. (experiments.jsonl IS tracked, see below)
data/raw/*
data/external/*
data/splits/*
!data/**/.gitkeep
*.zip
*.csv.gz
*.parquet
*.npy
*.png
*.pptx

# Model artifacts / probs / submissions (regenerable)
probs/*
submissions/*
reports/figs/*
!probs/.gitkeep
!submissions/.gitkeep
!reports/.gitkeep

# Keep the experiment diary source of truth tracked
!experiments.jsonl

# OS / IDE
.DS_Store
